{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Build Raylib Game",
            "command": "C:/raylib/w64devkit/bin/g++.exe",
            "args": [
                "D:/Rafi/SNake/src/main.c",
                "-o",
                "D:/Rafi/SNake/game.exe",
                "-I", "C:/raylib/raylib/src",
                "-L", "C:/raylib/raylib/src",
                "-lraylib",
                "-lopengl32",
                "-lgdi32",
                "-lwinmm"
            ],
            "options": {
                "env": {
                    "PATH": "C:\\raylib\\w64devkit\\bin;${env:PATH}"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}